CharacterService.java
javapackage com.example.Create_Character.services;

import com.example.Create_Character.models.Character;
import com.example.Create_Character.repos.CharacterRepo;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
public class CharacterService {

    private final CharacterRepo repo;

    public CharacterService(CharacterRepo repo) {
        this.repo = repo;
    }

    // get all characters for a user
    public List<Character> getAll(Long userId) {
        return repo.findByUserId(userId);
    }

    // get one character
    public Character getOne(Long id) {
        return repo.findById(id).orElseThrow();
    }

    // create a character
    public Character create(Character character) {
        return repo.save(character);
    }

    // update a character
    public Character update(Long id, Character updated) {
        Character existing = repo.findById(id).orElseThrow();
        existing.setName(updated.getName());
        existing.setAge(updated.getAge());
        existing.setClassId(updated.getClassId());
        existing.setElementId(updated.getElementId());
        return repo.save(existing);
    }

    // delete a character
    public void delete(Long id) {
        repo.deleteById(id);
    }
}

CharacterController.java
javapackage com.example.Create_Character.Controllers;

import com.example.Create_Character.models.Character;
import com.example.Create_Character.services.CharacterService;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController
@RequestMapping("/api/characters")
@CrossOrigin(origins = "http://localhost:5173")
public class CharacterController {

    private final CharacterService service;

    public CharacterController(CharacterService service) {
        this.service = service;
    }

    // GET all characters for a user
    @GetMapping("/user/{userId}")
    public List<Character> getAll(@PathVariable Long userId) {
        return service.getAll(userId);
    }

    // GET one character
    @GetMapping("/{id}")
    public Character getOne(@PathVariable Long id) {
        return service.getOne(id);
    }

    // POST create a character
    @PostMapping
    public Character create(@RequestBody Character character) {
        return service.create(character);
    }

    // PUT update a character
    @PutMapping("/{id}")
    public Character update(@PathVariable Long id, @RequestBody Character character) {
        return service.update(id, character);
    }

    // DELETE a character
    @DeleteMapping("/{id}")
    public void delete(@PathVariable Long id) {
        service.delete(id);
    }
}

